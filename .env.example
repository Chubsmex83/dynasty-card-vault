# Public site URL — used for canonical links, sitemap.xml, and JSON-LD.
# In Vercel this is set automatically per deployment; override for a custom domain.
NEXT_PUBLIC_SITE_URL=https://dynastycardvault.vercel.app

# Banxico SIE API token (free) — used to fetch the daily FIX exchange rate
# (series SF43718) for MXN→USD price conversion. Get one at:
# https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=

# USD conversion margin: USD = (MXN / FIX) * (1 + USD_MARGIN). 0.05 = 5%.
USD_MARGIN=0.05
