# Public site URL — used for canonical links, sitemap.xml, and JSON-LD.
# In Vercel this is set automatically per deployment; override for a custom domain.
NEXT_PUBLIC_SITE_URL=https://dynastycardvault.vercel.app

# Banxico SIE API token (free) — used to fetch the daily FIX exchange rate
# (series SF43718) for MXN→USD price conversion. Get one at:
# https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=

# USD conversion margin: USD = (MXN / FIX) * (1 + USD_MARGIN). 0.05 = 5%.
USD_MARGIN=0.05

# ---------------------------------------------------------------------------
# Payments (Phase 3). Use TEST/SANDBOX keys until we go live.
# ---------------------------------------------------------------------------

# Stripe México — domestic methods, charged in MXN (cards, Apple/Google Pay,
# OXXO, Meses Sin Intereses). Dashboard → Developers → API keys (Test mode).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_test_...
STRIPE_SECRET_KEY=                    # sk_test_...
STRIPE_WEBHOOK_SECRET=                # whsec_... (created when we add the webhook)

# PayPal — US / cross-border, charged in USD. developer.paypal.com →
# Apps & Credentials → Sandbox app.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox                    # "sandbox" or "live"
